{
  "schema_version": 2,
  "product": "Dusk Developer Studio Local Standalone",
  "channel": "node-sea-in-process",
  "canonical_repository": "GeorgianDusk/dusk-developer-studio",
  "workflow_path": ".github/workflows/studio-companion-signed-rc.yml",
  "protected_environment": "studio-companion-signing",
  "release_tag_pattern": "^studio-companion-v\\d+\\.\\d+\\.\\d+-rc\\.\\d+$",
  "publication_enabled": false,
  "publication_blocker": "Public binaries remain disabled because Windows and Apple signing identities are intentionally unconfigured, candidate transport and publication-evidence authentication are unavailable, and signed clean-machine evidence, independent security acceptance, tested support rehearsal, exact rollback and withdrawal drill evidence, and explicit publication approval are incomplete.",
  "same_user_tool_boundary": {
    "schema_version": 1,
    "decision": "accepted",
    "owner": "George",
    "accepted_at": "2026-07-18T00:00:00Z",
    "authority_reference": "docs/security/same-user-tool-boundary-decision.md",
    "scope": "allowlisted-local-developer-tools-current-user",
    "compensating_controls": [
      "separate-safe-and-local-actions-launchers",
      "privileged-launch-rejected",
      "exact-command-and-argument-allowlist",
      "no-user-controlled-or-arbitrary-shell-surface",
      "minimal-secret-stripped-child-environment",
      "bounded-time-output-concurrency-and-studio-managed-filesystem-effects",
      "tracked-direct-and-ordinary-process-group-termination",
      "studio-listener-recheck-and-fixed-port-closure",
      "machine-wide-process-cleanup-not-claimed",
      "public-companion-binaries-disabled"
    ],
    "residual_risk": "A hostile or compromised allowlisted developer tool runs with the user's account authority and can use that authority for filesystem, network, and process effects while active, including deliberately creating a detached same-user process that survives Studio shutdown and escapes portable child-process tracking.",
    "revisit_triggers": [
      "public-companion-binary-publication",
      "arbitrary-project-command-execution",
      "package-install-or-update-capability",
      "expanded-tool-allowlist",
      "administrator-or-service-capability",
      "same-user-tool-security-incident"
    ]
  },
  "candidate_transport": {
    "enabled": false,
    "provider": "none",
    "blocker": "No private signed-candidate transport has been implemented and independently reviewed; candidate binaries must not use GitHub Actions artifacts or draft releases."
  },
  "publication_evidence_contract": {
    "schema_version": 1,
    "maximum_candidate_age_days": 30,
    "maximum_clock_skew_minutes": 5,
    "maximum_monitoring_revisit_days": 90,
    "actor_identity_scheme": "github-login",
    "evidence_authentication": "not-implemented-schema-2",
    "required_gates": [
      "security_review",
      "support_incident_route",
      "compatibility",
      "rollback_revocation",
      "reputation_quarantine",
      "monitoring_revisit",
      "explicit_approval"
    ]
  },
  "payload_trust": {
    "platform_signed_assets": "each-launcher-or-app-bundle-only",
    "outer_zip_authentication": "not-established-until-reviewed-transport-binds-package-digest",
    "embedded_portable_payload": "internal-unsigned-release-candidate",
    "binding": "exact-build-receipt-unsigned-asset-index-and-package-manifest",
    "portable_directory_ed25519_publication_satisfied": false
  },
  "runner_labels": {
    "windows-x64": "windows-2025",
    "linux-x64": "ubuntu-24.04",
    "darwin-arm64": "macos-15"
  },
  "targets": {
    "windows-x64": {
      "distribution_format": "zip-with-two-authenticode-executables",
      "signing_provider": "azure-artifact-signing",
      "approved_identity": "",
      "identity_field": "publisher_subject",
      "required_checks": [
        "authenticode_valid",
        "timestamp_valid",
        "publisher_identity_verified",
        "fresh_runner_smoke_passed",
        "install_cleanup_verified",
        "malware_scan_passed",
        "install_rollback_verified"
      ]
    },
    "linux-x64": {
      "distribution_format": "zip-with-two-elf-launchers-and-sigstore-bundles",
      "signing_provider": "sigstore-keyless",
      "identity_field": "certificate_identity",
      "identity_template": "https://github.com/GeorgianDusk/dusk-developer-studio/.github/workflows/studio-companion-signed-rc.yml@refs/tags/{release_tag}",
      "approved_oidc_issuer": "https://token.actions.githubusercontent.com",
      "required_checks": [
        "cosign_bundle_verified",
        "rekor_inclusion_verified",
        "workflow_identity_verified",
        "fresh_runner_smoke_passed",
        "install_cleanup_verified",
        "install_rollback_verified"
      ]
    },
    "darwin-arm64": {
      "distribution_format": "zip-with-two-stapled-app-bundles",
      "signing_provider": "apple-developer-id-notary",
      "approved_identity": "",
      "identity_field": "apple_team_id",
      "required_checks": [
        "developer_id_valid",
        "hardened_runtime",
        "notarized",
        "ticket_stapled",
        "gatekeeper_assessed",
        "fresh_runner_smoke_passed",
        "install_cleanup_verified",
        "install_rollback_verified"
      ]
    }
  }
}
